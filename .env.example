# Django Settings
DEBUG=0
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/nexus

# Redis & Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email (for notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# File Storage
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# Static Files
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles

# Security
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0

# Monitoring (optional)
SENTRY_DSN=

# AI Providers (optional)
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── AI Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-claude-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here
# Provider order (comma-separated, first available is used)
AI_PROVIDER_ORDER=anthropic,openai,gemini,groq

# ── Security ──────────────────────────────────────────────────────────────
# Immutable audit ledger signing key (use a different key from SECRET_KEY)
AUDIT_SIGNING_KEY=your-audit-signing-key-change-in-production
# Enable Zero-Trust middleware (set false in development)
ZERO_TRUST_ENABLED=true

# ── ZATCA Phase 2 (Saudi Arabia) ─────────────────────────────────────────
# Base64-encoded ZATCA certificate and private key
ZATCA_CERT=
ZATCA_PRIVATE_KEY=
# Set to false for production
ZATCA_SANDBOX=true

# ── ChromaDB (RAG Memory) ────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/var/lib/nexus/chroma

# ── Sentry Error Tracking ───────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Feature Flags ────────────────────────────────────────────────────────
PLUGIN_SANDBOX_ENABLED=true
SELF_IMPROVEMENT_ENABLED=true
